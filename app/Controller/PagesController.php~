			  } else {
				foreach ($academicCalendars as $ack=>&$ackv) {
				$department_ids=unserialize($ackv['AcademicCalendar']['department_id']);
				$year_level_ids=unserialize($ackv['AcademicCalendar']['year_level_id']);
				$found=false;

