<?php
if(count($orderedItemsLists) > 0) {
	foreach($orderedItemsLists as $label => $list) {
		echo "<optgroup label='".$label."'>";
		foreach($list as $key => $value) {
			echo "<option value='".$key."'>".$value."</option>";
		}
		echo "</optgroup>";
	}
}
