       // some condition(s) to validate each input
      
        if ($(e).val()!=""){
            // validation passed
            allValid = true;
        } else {
            // validation failed
            allValid = false;
        }
        
    });
    
    if (allValid) {
		var tabIndex = $(this).parents('.tab-pane').index();
        validated($('[data-toggle]').eq(tabIndex+1));
        $('#ListOfTab  > .active').next('li').find('a').trigger('click');
    } else {
    	//alert(allValid);
    	//$('[data-toggle=tab]').addClass("disabledTab");
    } 
   
});

