   function field_comparison($check1, $operator, $field2) { 
        foreach($check1 as $key=>$value1) { 
            $value2 = $this->data[$this->alias][$field2]; 
            if (!Validation::comparison($value1, $operator, $value2)) 
                return false; 
        } 
        return true; 
    }
